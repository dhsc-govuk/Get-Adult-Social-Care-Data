{
  "name": "dhsc-dap-alpha",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "start:testmode": "E2E_TESTING_MODE=true next start",
    "lint": "eslint .",
    "format": "prettier --write",
    "lint-staged": "lint-staged",
    "test": "vitest run --coverage",
    "test:nocov": "vitest run",
    "test:watch": "vitest",
    "test:setupusers": "tsx ./TestData/setup-test-users.ts",
    "cypress": "cypress open --e2e",
    "cypress:headless": "cypress run --e2e",
    "db:test:seed": "tsx ./TestData/seed-test-database.ts",
    "db:migrate": " ./node_modules/@better-auth/cli/dist/index.mjs migrate",
    "db:migrate:ci": " ./node_modules/@better-auth/cli/dist/index.mjs migrate --yes",
    "db:user:add": "tsx scripts/bootstrap-user.ts",
    "openapi:lint": "redocly lint --extends recommended ../gascd_metrics_api/openapi.yaml",
    "openapi:types:generate": "openapi-typescript ../gascd_metrics_api/openapi.yaml -o ./src/metrics-api-schema.d.ts",
    "openapi:types:check": "openapi-typescript ../gascd_metrics_api/openapi.yaml -o ./src/metrics-api-schema.d.ts --check"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": "eslint --config eslint.config.js",
    "**/*.{js,jsx,ts,tsx,json,css,md}": "prettier --write"
  },
  "dependencies": {
    "@azure/monitor-opentelemetry": "^1.11.1",
    "@better-auth/cli": "^1.4.7",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-regular-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@microsoft/applicationinsights-react-js": "^19.3.7",
    "@microsoft/applicationinsights-web": "^3.3.9",
    "@ministryofjustice/frontend": "^8.0.0",
    "@next/eslint-plugin-next": "15.5.2",
    "@opentelemetry/auto-instrumentations-node": "^0.62.0",
    "@types/d3": "^7.4.3",
    "@x-govuk/govuk-prototype-components": "^5.0.2",
    "better-auth": "^1.4.7",
    "d3": "^7.9.0",
    "govuk-frontend": "^5.13.0",
    "history": "^5.3.0",
    "js-cookie": "^3.0.5",
    "jsdom": "^27.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "moment": "^2.30.1",
    "mssql": "^11.0.1",
    "msw": "^2.7.3",
    "next": "^15.5.10",
    "plotly.js": "^3.3.0",
    "react": "19.1.3",
    "react-dom": "19.1.3",
    "react-plotly.js": "^2.6.0",
    "server-only": "^0.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.1",
    "@eslint/js": "^9.32.0",
    "@redocly/cli": "^2.15.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/govuk-frontend": "^5.9.0",
    "@types/js-cookie": "^3.0.6",
    "@types/mssql": "^9.1.6",
    "@types/node": "^24.1.0",
    "@types/plotly.js": "^3.0.8",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "@types/react-plotly.js": "^2.6.4",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "axe-html-reporter": "^2.2.11",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.23.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^16.0.0",
    "identity-obj-proxy": "^3.0.0",
    "lint-staged": "^16.1.2",
    "msw": "^2.7.3",
    "openapi-fetch": "^0.15.0",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.4.2",
    "sass": "^1.89.2",
    "tsx": "^4.20.6",
    "typescript": "5.7.2",
    "typescript-eslint": "^8.0.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.16"
  },
  "optionalDependencies": {
    "cypress": "^13.17.0"
  },
  "overrides": {
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "lodash": "4.17.23",
    "fast-xml-parser": "5.3.4"
  }
}
